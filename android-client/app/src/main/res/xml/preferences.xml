<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="Transport">

        <ListPreference
            android:key="transport"
            android:title="Transport"
            android:summary="How the PC connects to this device"
            android:defaultValue="wifi"
            android:entries="@array/transport_entries"
            android:entryValues="@array/transport_values" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Audio">

        <ListPreference
            android:key="audio_source"
            android:title="Audio source"
            android:summary="Microphone input source"
            android:defaultValue="mic"
            android:entries="@array/audio_source_entries"
            android:entryValues="@array/audio_source_values" />

        <ListPreference
            android:key="sample_rate"
            android:title="Sample Rate"
            android:summary="Audio sample rate"
            android:defaultValue="48000"
            android:entries="@array/sample_rate_entries"
            android:entryValues="@array/sample_rate_values" />

        <ListPreference
            android:key="codec"
            android:title="Codec"
            android:summary="Audio codec"
            android:defaultValue="0"
            android:entries="@array/codec_entries"
            android:entryValues="@array/codec_values" />

        <SwitchPreferenceCompat
            android:key="stereo"
            android:title="Stereo"
            android:summary="Record in stereo (if supported)"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Network">

        <EditTextPreference
            android:key="server_port"
            android:title="Server port"
            android:summary="Port for PC client to connect"
            android:defaultValue="8125" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Misc">

        <SwitchPreferenceCompat
            android:key="noise_suppression"
            android:title="Noise Suppression"
            android:summary="Reduce background noise"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="keep_screen_on"
            android:title="Keep Screen On"
            android:summary="Prevent screen from turning off while streaming"
            android:defaultValue="false" />

    </PreferenceCategory>

</PreferenceScreen>
