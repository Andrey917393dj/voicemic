<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#303030">

    <!-- Toolbar (action bar) -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#424242"
        app:titleTextColor="#FFFFFF"
        app:title="VoiceMic"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

    <!-- Main content — centered -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Large mic icon -->
            <ImageView
                android:id="@+id/mic_icon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:layout_marginBottom="24dp"
                android:contentDescription="Microphone"
                android:tint="#808080" />

            <!-- Status text: Idle / Waiting / Connected -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idle"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <!-- Transport + IP:port (shown when server running) -->
            <TextView
                android:id="@+id/ip_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:textColor="#AAAAAA"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- Audio level bar (shown when connected) -->
            <ProgressBar
                android:id="@+id/audio_level_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:visibility="gone"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#555555"
                android:layout_marginBottom="12dp" />

            <!-- Mute button (shown when connected) -->
            <ImageView
                android:id="@+id/mute_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:contentDescription="Mute"
                android:visibility="gone"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF" />

        </LinearLayout>

    </RelativeLayout>

</LinearLayout>
